# === Line endings ===
*.sh text eol=lf
*.bash text eol=lf
/mvnw text eol=lf

# === GitHub linguist: reduce peso de templates reusables ===
# Estos se incluyen en muchos otros → exclúyelos del conteo
src/main/resources/templates/base.html linguist-generated=true
src/main/resources/templates/_*.html linguist-generated=true

# Si usas una carpeta "fragments" (aunque no la vea), añade esto:
# src/main/resources/templates/fragments/*.html linguist-generated=true

# === Mantén el resto visible (pero con menos líneas gracias a base.html extraído) ===
# Los siguientes seguirán contando como HTML, pero con menos líneas totales:
# - add_product.html
# - edit_product.html
# - cart.html
# - order.html
# - etc.

# === Assets (opcional, pero recomendado) ===
*.png linguist-generated=true
*.jpg linguist-generated=true
*.jpeg linguist-generated=true
*.gif linguist-generated=true
*.svg linguist-generated=true
*.ico linguist-generated=true

# === Build & IDE ===
target/** linguist-generated=true
build/** linguist-generated=true
.vscode/** linguist-generated=true
*.iml linguist-generated=true